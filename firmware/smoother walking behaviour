)rawliteral";

// --- OLED Screen Update Helper ---
void updateDisplay(const char* statusText, const char* detailText) {
    display.clearDisplay();
    display.setTextColor(SSD1306_WHITE);
    
    display.setTextSize(2);
    display.setCursor(8, 8);
    display.print("TARS VECTOR");
    
    display.setTextSize(1);
    display.setCursor(8, 38);
    display.print(statusText);
    display.setCursor(8, 50);
    display.print(detailText);
    
    display.display();
}

// --- Web Server Request Handlers ---
void handleRoot() {
    server.send(200, "text/html", HTML_INTERFACE);
}

void handleVector() {
    if (server.hasArg("x") && server.hasArg("y")) {
        joystickX = server.arg("x").toInt();
        joystickY = server.arg("y").toInt();

        if (joystickX == 0 && joystickY == 0) {
            servoLeft.write(leftOffset);
            servoRight.write(rightOffset);
            updateDisplay("STATUS: IDLE", "STABLE HOMED");
        }
        server.send(200, "text/plain", "OK");
    } else {
        server.send(400, "text/plain", "Bad Request");
    }
}

void handleConfig() {
    if (server.hasArg("l_off") && server.hasArg("r_off")) {
        leftOffset = server.arg("l_off").toInt();
        rightOffset = server.arg("r_off").toInt();

        if (joystickX == 0 && joystickY == 0) {
            servoLeft.write(leftOffset);
            servoRight.write(rightOffset);
        }
        server.send(200, "text/plain", "OK");
    } else {
        server.send(400, "text/plain", "Bad Request");
    }
}

// --- Smooth Differential Mixing Gait Engine ---
void executeProportionalGait() {
    if (joystickX == 0 && joystickY == 0) return;

    unsigned long currentMillis = millis();
    // Dynamic speed scaling: higher joystick Y magnitude increases step pace slightly, lower scales it down
    unsigned long currentInterval = baseGaitInterval; 

    if (currentMillis - lastStepTime >= currentInterval) {
        lastStepTime = currentMillis;

        // Calculate dynamic amplitude proportional to joystick Y push (capped between 2 and 6 degrees)
        int dynamicAmplitude = map(abs(joystickY), 0, 100, 2, 6);
        
        // Calculate differential turning bias from joystick X push
        // Positive X turns right (adds to right, subtracts from left or vice versa)
        int turnBias = map(joystickX, -100, 100, -3, 3);

        int targetLeft, targetRight;

        if (joystickY >= 0) { // Forward movement range
            if (gaitStepState == 0) {
                targetLeft  = leftOffset + dynamicAmplitude + turnBias;
                targetRight = rightOffset - dynamicAmplitude + turnBias;
                gaitStepState = 1;
            } else {
                targetLeft  = leftOffset - dynamicAmplitude + turnBias;
                targetRight = rightOffset + dynamicAmplitude + turnBias;
                gaitStepState = 0;
            }
            updateDisplay("MOVING: FWD", "PROPORTIONAL MIX");
        } else { // Backward movement range
            if (gaitStepState == 0) {
                targetLeft  = leftOffset - dynamicAmplitude + turnBias;
                targetRight = rightOffset + dynamicAmplitude + turnBias;
                gaitStepState = 1;
            } else {
                targetLeft  = leftOffset + dynamicAmplitude + turnBias;
                targetRight = rightOffset - dynamicAmplitude + turnBias;
                gaitStepState = 0;
            }
            updateDisplay("MOVING: REV", "PROPORTIONAL MIX");
        }

        // Apply smooth angles safely
        servoLeft.write(constrain(targetLeft, 60, 120));
        servoRight.write(constrain(targetRight, 60, 120));
    }
}

void setup() {
    Serial.begin(115200);

    // Initialize OLED Display
    if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
        Serial.println("OLED init failed");
        for(;;);
    }
    updateDisplay("BOOTING", "CONNECTING WIFI");

    // Initialize Servos to Trim Offsets
    servoLeft.attach(SERVO_LEFT_PIN);
    servoRight.attach(SERVO_RIGHT_PIN);
    servoLeft.write(leftOffset);
    servoRight.write(rightOffset);

    // Connect to Wi-Fi
    WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
    int attempts = 0;
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        Serial.print(".");
        attempts++;
        if (attempts > 30) {
            updateDisplay("WIFI FAILED", "REBOOTING...");
            delay(2000);
            ESP.restart();
        }
    }

    String ipMsg = WiFi.localIP().toString();
    updateDisplay("ONLINE", ipMsg.c_str());

    // Register Web Server Routes
    server.on("/", handleRoot);
    server.on("/vector", handleVector);
    server.on("/config", handleConfig);
    server.begin();
}

void loop() {
    server.handleClient();     // Listen for live vector touch updates
    executeProportionalGait(); // Execute continuous differential blending
}
