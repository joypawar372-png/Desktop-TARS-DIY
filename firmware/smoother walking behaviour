// --- OLED Screen Helper ---
void updateDisplay(String statusText) {
    display.clearDisplay();
    display.setTextColor(SSD1306_WHITE);
    
    display.setTextSize(1);
    display.setCursor(0, 0);
    display.print("SINE GAIT KINEMATICS");
    display.drawLine(0, 10, 128, 10, SSD1306_WHITE);
    
    display.setTextSize(2);
    display.setCursor(0, 22);
    display.print(customMessage);
    
    display.setTextSize(1);
    display.setCursor(0, 52);
    display.print("STATUS: ");
    display.print(statusText);
    
    display.display();
}

// --- Web Handlers ---
void handleRoot() { server.send(200, "text/html", HTML_INTERFACE); }

void handleVector() {
    if (server.hasArg("x") && server.hasArg("y")) {
        targetX = server.arg("x").toFloat();
        targetY = server.arg("y").toFloat();
        server.send(200, "text/plain", "OK");
    }
}

void handleConfig() {
    if (server.hasArg("phase")) phaseShift = server.arg("phase").toFloat();
    if (server.hasArg("freq"))  gaitFreq   = server.arg("freq").toFloat();
    if (server.hasArg("amp"))   maxAmplitude = server.arg("amp").toFloat();
    if (server.hasArg("lean"))  leanBias   = server.arg("lean").toFloat();
    if (server.hasArg("sm"))    smoothness = server.arg("sm").toFloat();
    if (server.hasArg("l_off")) leftOffset = server.arg("l_off").toFloat();
    if (server.hasArg("r_off")) rightOffset = server.arg("r_off").toFloat();
    
    server.send(200, "text/plain", "OK");
}

void handleText() {
    if (server.hasArg("msg")) {
        customMessage = server.arg("msg");
        customMessage.toUpperCase();
        updateDisplay("TEXT UPDATED");
        server.send(200, "text/plain", "OK");
    }
}

// --- Smooth Harmonic Gait Engine (50Hz Loop) ---
void updateHarmonicGait() {
    unsigned long currentMillis = millis();
    float dt = (currentMillis - lastLoopTime) / 1000.0;
    
    // Maintain strict 20ms execution cycle (50 Hz)
    if (dt < 0.02) return; 
    lastLoopTime = currentMillis;

    // 1. Exponential Moving Average (Lerp Filter) for Joystick Input
    // Completely removes jerks when abruptly releasing or flicking the joystick
    currentX += (targetX - currentX) * smoothness;
    currentY += (targetY - currentY) * smoothness;

    float magnitude = sqrt(currentX * currentX + currentY * currentY) / 100.0;

    // 2. Idle State: Return smoothly to trim offsets
    if (magnitude < 0.05) {
        currentLeftAngle += (leftOffset - currentLeftAngle) * smoothness;
        currentRightAngle += (rightOffset - currentRightAngle) * smoothness;
        
        servoLeft.write((int)currentLeftAngle);
        servoRight.write((int)currentRightAngle);
        phaseAngle = 0.0; // Reset phase
        return;
    }

    // 3. Increment Phase Angle linearly over time
    phaseAngle += 2.0 * M_PI * gaitFreq * dt;
    if (phaseAngle >= 2.0 * M_PI) phaseAngle -= 2.0 * M_PI;

    // 4. Calculate Differential Arcade Ratios
    float v = currentY / 100.0; // Forward / Reverse (-1.0 to 1.0)
    float w = currentX / 100.0; // Pivot / Turn (-1.0 to 1.0)

    float leftGain  = v + w;
    float rightGain = v - w;

    // Normalize gains if they exceed 1.0
    float maxGain = max(abs(leftGain), abs(rightGain));
    if (maxGain > 1.0) {
        leftGain /= maxGain;
        rightGain /= maxGain;
    }

    // 5. Generate Continuous Sinusoidal Trajectories
    float phaseRadShift = phaseShift * (M_PI / 180.0);
    
    float leftSine  = sin(phaseAngle);
    float rightSine = sin(phaseAngle + phaseRadShift);

    // Dynamic CoG Lean Bias (Lifts front/back depending on direction)
    float dynamicLean = v * leanBias;

    // Calculate final smooth angles
    float targetLeftDeg  = leftOffset  + dynamicLean + (leftGain  * maxAmplitude * leftSine);
    float targetRightDeg = rightOffset - dynamicLean - (rightGain * maxAmplitude * rightSine);

    // Apply Lerp filtering to output angles for sub-degree smoothness
    currentLeftAngle  += (targetLeftDeg  - currentLeftAngle)  * 0.4;
    currentRightAngle += (targetRightDeg - currentRightAngle) * 0.4;

    // Write directly to Servos (Constrained safely between 15 and 165 degrees)
    servoLeft.write((int)constrain(currentLeftAngle, 15.0, 165.0));
    servoRight.write((int)constrain(currentRightAngle, 15.0, 165.0));

    // Update OLED state telemetry periodically
    if (abs(currentX) > abs(currentY) + 20) updateDisplay("PIVOT TURN");
    else if (currentY > 10) updateDisplay("SMOOTH WALK");
    else if (currentY < -10) updateDisplay("SMOOTH REV");
}

void setup() {
    Serial.begin(115200);

    // Initialize OLED Display
    if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
        Serial.println("OLED init failed");
        for(;;);
    }

    // Connect to Wi-Fi
    WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
    display.clearDisplay();
    display.setTextColor(SSD1306_WHITE);
    display.setTextSize(2);
    display.setCursor(0, 20);
    display.print("CONNECTING");
    display.display();

    int attempts = 0;
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        attempts++;
        if (attempts > 30) ESP.restart();
    }

    customMessage = WiFi.localIP().toString();
    updateDisplay("SYS ONLINE");

    // Initialize Servos
    servoLeft.attach(SERVO_LEFT_PIN);
    servoRight.attach(SERVO_RIGHT_PIN);
    servoLeft.write((int)leftOffset);
    servoRight.write((int)rightOffset);

    // Register Server Routes
    server.on("/", handleRoot);
    server.on("/vector", handleVector);
    server.on("/config", handleConfig);
    server.on("/text", handleText);
    server.begin();
}

void loop() {
    server.handleClient();
    updateHarmonicGait(); // Runs at a smooth 50 Hz refresh rate
}
