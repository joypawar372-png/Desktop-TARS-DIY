// --- OLED Update Helper ---
void updateDisplay(const char* statusText, const char* detailText) {
    display.clearDisplay();
    display.setTextColor(SSD1306_WHITE);
    
    display.setTextSize(2);
    display.setCursor(8, 8);
    display.print("TARS MOTION");
    
    display.setTextSize(1);
    display.setCursor(8, 38);
    display.print(statusText);
    display.setCursor(8, 50);
    display.print(detailText);
    
    display.display();
}

// --- Web Server Request Handlers ---
void handleRoot() {
    server.send(200, "text/html", HTML_INTERFACE);
}

void handleCommand() {
    if (server.hasArg("action")) {
        String action = server.arg("action");
        if (action == "forward") currentMode = 1;
        else if (action == "backward") currentMode = 2;
        else if (action == "left") currentMode = 3;
        else if (action == "right") currentMode = 4;
        else if (action == "stop" || action == "home") {
            currentMode = 0;
            servoLeft.write(leftOffset);
            servoRight.write(rightOffset);
            updateDisplay("STATUS: IDLE", "POSTURE: HOMED");
        }
        server.send(200, "text/plain", "OK");
    } else {
        server.send(400, "text/plain", "Bad Request");
    }
}

void handleConfig() {
    if (server.hasArg("amp") && server.hasArg("l_off") && server.hasArg("r_off")) {
        stepAmplitude = server.arg("amp").toInt();
        leftOffset = server.arg("l_off").toInt();
        rightOffset = server.arg("r_off").toInt();

        // If stationary, immediately snap to the new independent offsets
        if (currentMode == 0) {
            servoLeft.write(leftOffset);
            servoRight.write(rightOffset);
        }
        server.send(200, "text/plain", "OK");
    } else {
        server.send(400, "text/plain", "Bad Request");
    }
}

// --- Slow, Stable Gait Engine ---
void executeGaitCycle() {
    if (currentMode == 0) return;

    unsigned long currentMillis = millis();
    if (currentMillis - lastStepTime >= gaitInterval) {
        lastStepTime = currentMillis;

        if (currentMode == 1) { // Forward Walking Cycle
            if (gaitStepState == 0) {
                servoLeft.write(leftOffset + stepAmplitude);
                servoRight.write(rightOffset - stepAmplitude);
                gaitStepState = 1;
            } else {
                servoLeft.write(leftOffset - stepAmplitude);
                servoRight.write(rightOffset + stepAmplitude);
                gaitStepState = 0;
            }
            updateDisplay("WALKING", "SLOW FWD GAIT");
        } 
        else if (currentMode == 2) { // Backward Walking Cycle
            if (gaitStepState == 0) {
                servoLeft.write(leftOffset - stepAmplitude);
                servoRight.write(rightOffset + stepAmplitude);
                gaitStepState = 1;
            } else {
                servoLeft.write(leftOffset + stepAmplitude);
                servoRight.write(rightOffset - stepAmplitude);
                gaitStepState = 0;
            }
            updateDisplay("WALKING", "SLOW REV GAIT");
        }
        else if (currentMode == 3) { // Shift Left
            servoLeft.write(leftOffset + stepAmplitude);
            servoRight.write(rightOffset + stepAmplitude);
            updateDisplay("TURNING", "LEANING LEFT");
        }
        else if (currentMode == 4) { // Shift Right
            servoLeft.write(leftOffset - stepAmplitude);
            servoRight.write(rightOffset - stepAmplitude);
            updateDisplay("TURNING", "LEANING RIGHT");
        }
    }
}

void setup() {
    Serial.begin(115200);

    // Initialize OLED screen
    if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
        Serial.println("OLED initialization failed");
        for(;;);
    }
    updateDisplay("BOOTING", "CONNECTING WIFI");

    // Attach Servos and move to initial offsets
    servoLeft.attach(SERVO_LEFT_PIN);
    servoRight.attach(SERVO_RIGHT_PIN);
    servoLeft.write(leftOffset);
    servoRight.write(rightOffset);

    // Connect to WiFi
    WiFi.begin("YOUR_WIFI_SSID", "YOUR_WIFI_PASSWORD");
    while (WiFi.status() != WL_CONNECTED) {
        delay(400);
        Serial.print(".");
    }

    String ipMsg = WiFi.localIP().toString();
    updateDisplay("ONLINE", ipMsg.c_str());

    // Register Server Routes
    server.on("/", handleRoot);
    server.on("/cmd", handleCommand);
    server.on("/config", handleConfig);
    server.begin();
}

void loop() {
    server.handleClient(); // Handle incoming mobile browser commands & sliders
    executeGaitCycle();    // Run the slow, non-blocking walking rhythm
}
