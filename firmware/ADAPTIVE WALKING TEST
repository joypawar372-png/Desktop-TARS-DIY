        .subtitle { color: #888; font-size: 12px; margin-bottom: 20px; }
        .card { background: #1E1E1E; border-radius: 12px; padding: 15px; margin-bottom: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); text-align: left; }
        .card h3 { text-align: center; margin-top: 0; color: #007AFF; font-size: 15px; letter-spacing: 1px; }
        
        /* Joystick Styling */
        #joystick-container { position: relative; width: 160px; height: 160px; background: #2A2A2A; border-radius: 50%; margin: 10px auto; touch-action: none; border: 2px solid #444; }
        #stick { position: absolute; width: 60px; height: 60px; background: #007AFF; border-radius: 50%; top: 50px; left: 50px; box-shadow: 0 4px 8px rgba(0,0,0,0.4); transition: transform 0.05s ease-out; }
        
        .btn { background: #333; color: white; border: none; padding: 12px 20px; font-size: 14px; border-radius: 8px; margin: 5px; cursor: pointer; width: 48%; }
        .btn-stop { background: #FF3B30; width: 100%; font-weight: bold; margin-top: 5px; }
        
        .slider-container { margin: 12px 0; }
        label { font-weight: bold; font-size: 12px; color: #AAA; display: block; margin-bottom: 4px; }
        .slider { -webkit-appearance: none; width: 100%; height: 10px; border-radius: 5px; background: #333; outline: none; }
        .slider::-webkit-slider-thumb { -webkit-appearance: none; width: 22px; height: 22px; border-radius: 50%; background: #007AFF; cursor: pointer; }
        .value-display { float: right; color: #007AFF; font-weight: bold; }
    </style>
</head>
<body>
    <h1>TARS</h1>
    <div class="subtitle">PRECISION GAIT & SERVO MATRIX</div>

    <div class="card" style="text-align: center;">
        <h3>DIRECTIONAL JOYSTICK</h3>
        <div id="joystick-container">
            <div id="stick"></div>
        </div>
        <button class="btn btn-stop" onclick="sendCommand('stop')">EMERGENCY STOP</button>
    </div>

    <div class="card">
        <h3>SERVO & GAIT TUNING</h3>
        
        <div class="slider-container">
            <label>STEP OSCILLATION ANGLE <span id="ampVal" class="value-display">4&deg;</span></label>
            <input type="range" min="1" max="8" value="4" class="slider" id="ampSlider" onchange="updateConfig()">
        </div>

        <div class="slider-container">
            <label>LEFT SERVO OFFSET <span id="leftVal" class="value-display">90&deg;</span></label>
            <input type="range" min="75" max="105" value="90" class="slider" id="leftSlider" onchange="updateConfig()">
        </div>

        <div class="slider-container">
            <label>RIGHT SERVO OFFSET <span id="rightVal" class="value-display">90&deg;</span></label>
            <input type="range" min="75" max="105" value="90" class="slider" id="rightSlider" onchange="updateConfig()">
        </div>
    </div>

    <script>
        const container = document.getElementById('joystick-container');
        const stick = document.getElementById('stick');
        let active = false;
        let lastCommand = "";

        function sendCommand(cmd) {
            if (cmd === lastCommand && cmd !== 'stop') return;
            lastCommand = cmd;
            fetch('/cmd?action=' + cmd);
        }

        function updateConfig() {
            let amp = document.getElementById('ampSlider').value;
            let l_off = document.getElementById('leftSlider').value;
            let r_off = document.getElementById('rightSlider').value;

            document.getElementById('ampVal').innerText = amp + '°';
            document.getElementById('leftVal').innerText = l_off + '°';
            document.getElementById('rightVal').innerText = r_off + '°';

            fetch(`/config?amp=${amp}&l_off=${l_off}&r_off=${r_off}`);
        }

        // Joystick Touch Mechanics
        function handleMove(clientX, clientY) {
            const rect = container.getBoundingClientRect();
            let x = clientX - rect.left - 80;
            let y = clientY - rect.top - 80;
            let dist = Math.sqrt(x * x + y * y);
            let maxDist = 50;

            if (dist > maxDist) {
                x = (x / dist) * maxDist;
                y = (y / dist) * maxDist;
            }

            stick.style.transform = `translate(${x}px, ${y}px)`;

            if (y < -20) sendCommand('forward');
            else if (y > 20) sendCommand('backward');
            else if (x < -20) sendCommand('left');
            else if (x > 20) sendCommand('right');
            else sendCommand('stop');
        }

        container.addEventListener('pointerdown', (e) => { active = true; handleMove(e.clientX, e.clientY); });
        window.addEventListener('pointermove', (e) => { if (active) handleMove(e.clientX, e.clientY); });
        window.addEventListener('pointerup', () => {
            if (!active) return;
            active = false;
            stick.style.transform = `translate(0px, 0px)`;
            sendCommand('stop');
        });
